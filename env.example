# Gmail(smtp.gmail.com) 在中国大陆网络下常无法直连，会报 ETIMEDOUT；可改用 QQ/163/Outlook 或在 GitHub Actions 上发信。
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
MAIL_TO=you@example.com
MAIL_FROM=

# 摘要使用的日历时区（默认 Asia/Shanghai）
DIGEST_TZ=Asia/Shanghai

# 推荐填写：网页与邮件中的「简述 + 外行补充 + 面试一句」（不填则仅 RSS 原文）
# 一行即可，不要写成 OPENAI_API_KEY = xxx（等号旁不要空格）；一般不要加引号
OPENAI_API_KEY=
# 旗舰文本模型；若账号暂无权限可改为 gpt-4o 或 gpt-4o-mini
OPENAI_MODEL=gpt-4.1
# 可选：不传则 gpt-5* 不带 temperature（避免 400）；其它模型默认 0.35
# OPENAI_TEMPERATURE=1
# 官方默认 https://api.openai.com；若网关 URL 已含末尾 /v1，程序会自动拼 /chat/completions
# OPENAI_BASE_URL=https://api.openai.com
#
# 若报错 invalid_issuer / not from a valid issuer：说明 Key 与 BASE_URL 不匹配
#（例如用 A 平台的 Key 去请求 api.openai.com）。请使用「该平台」提供的地址+Key 成套配置。
